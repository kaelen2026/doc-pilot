{
  "name": "doc-pilot",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.1",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:local": "docker compose up -d && turbo run dev",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "compose:up": "docker compose up -d",
    "compose:down": "docker compose down",
    "db:generate": "pnpm --filter @doc-pilot/database db:generate",
    "db:migrate": "pnpm --filter @doc-pilot/database db:migrate",
    "commitlint": "commitlint",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "turbo": "2.10.5",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,jsonc}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
