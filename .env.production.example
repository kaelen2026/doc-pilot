# 生产环境变量示例。复制为 .env.production 并按实际填写:
#   cp .env.production.example .env.production
# 用 docker env_file 格式(KEY=VALUE,不要 export)。带 [secret] 的务必用真实强随机值,
# 且不要提交进仓库。主机名默认用 compose 的 service 名(postgres/redis/minio);换托管
# 服务时把 DATABASE_URL / REDIS_URL / S3_* 指向托管端点即可。

# --- 自托管 Postgres 服务凭据(compose 用) ---
POSTGRES_USER=docpilot
POSTGRES_PASSWORD=change-me-strong          # [secret]
POSTGRES_DB=docpilot

# --- API ---
API_PORT=3001
# 允许携带 Cookie 跨源访问 API 的前端源(即 web 的公网地址)
WEB_ORIGIN=https://app.example.com

# --- Auth (Better Auth) ---
BETTER_AUTH_SECRET=change-me-openssl-rand-base64-32   # [secret] openssl rand -base64 32
BETTER_AUTH_URL=https://api.example.com

# --- Web(build 期内联,见 docker-compose.prod.yml 的 build args) ---
NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_APP_URL=https://app.example.com

# --- PostgreSQL(pgvector);托管则改为托管连接串 ---
DATABASE_URL=postgres://docpilot:change-me-strong@postgres:5432/docpilot   # [secret]

# --- Redis;托管则改为托管连接串 ---
REDIS_URL=redis://redis:6379

# --- Worker ---
WORKER_CONCURRENCY=2
OUTBOX_POLL_INTERVAL_MS=2000

# --- 可观测性 ---
LOG_LEVEL=info
# 各进程独立命名空间,api 与 worker 可用同一端口。不设则不启动 /metrics。
# METRICS_PORT=9464

# --- 对象存储(自托管 MinIO;生产建议 Cloudflare R2 / AWS S3) ---
S3_ENDPOINT=http://minio:9000              # R2/S3 时改为其 endpoint
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin                # [secret]
S3_SECRET_ACCESS_KEY=change-me-strong      # [secret]
S3_BUCKET=docpilot-private
S3_FORCE_PATH_STYLE=true                   # MinIO 用 true;R2/S3 视情况(多数用 false)
UPLOAD_URL_EXPIRES_SECONDS=900

# --- 邮件(登录验证码 SMTP) ---
# 注意:当前 packages/auth/src/mailer.ts 用无鉴权 SMTP(secure:false,无 user/pass)。
# 接真实邮件服务(需账号密码/TLS)前,需扩展 mailer;否则验证码发不出去。
SMTP_HOST=smtp.example.com
SMTP_PORT=587
MAIL_FROM=DocPilot <no-reply@example.com>

# --- AI Providers ---
# 不设则回落 mock(占位输出,不能用于生产)。生产必须配真实 Key。
ANTHROPIC_API_KEY=                         # [secret]
OPENAI_API_KEY=                            # [secret]
# AI_ANSWER_MODEL=claude-opus-4-8
# AI_SUMMARIZE_MODEL=claude-opus-4-8
# AI_EMBEDDING_MODEL=text-embedding-3-small

# --- RAG ---
# 真实 embedding 分数为正,保持 0 即可(mock 伪向量才需要 -1)。
RAG_MIN_SCORE=0
