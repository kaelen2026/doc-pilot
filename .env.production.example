# 生产环境变量示例。复制为 .env.production 并按实际填写:
#   cp .env.production.example .env.production
# 用 docker env_file 格式(KEY=VALUE,不要 export)。带 [secret] 的务必用真实强随机值,
# 且不要提交进仓库。主机名默认用 compose 的 service 名(postgres/redis/minio);换托管
# 服务时把 DATABASE_URL / REDIS_URL / S3_* 指向托管端点即可。

# --- 自托管 Postgres 服务凭据(compose 用) ---
POSTGRES_USER=docpilot
POSTGRES_PASSWORD=change-me-strong          # [secret] 必填:缺失时 compose 拒绝启动(fail-fast)
POSTGRES_DB=docpilot

# --- API ---
API_PORT=3001
# 允许携带 Cookie 跨源访问 API 的前端源(即 web 的公网地址)
WEB_ORIGIN=https://app.example.com
# 平台管理后台 /admin 的访问白名单(逗号分隔,大小写不敏感)。见 cross-cutting.md §25.3。
# 留空则无人可访问 /admin。按需最小授予。
# ADMIN_EMAILS=ops@example.com

# --- Auth (Better Auth) ---
BETTER_AUTH_SECRET=change-me-openssl-rand-base64-32   # [secret] openssl rand -base64 32
BETTER_AUTH_URL=https://api.example.com
# Sign in with Apple(可选)。四项凭据齐备才注册;client secret 由私钥动态签发,无需单独配。
# 原生 iOS 须配 APP_BUNDLE_IDENTIFIER 以校验 idToken 的 aud。
# APPLE_CLIENT_ID=
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_APP_BUNDLE_IDENTIFIER=dev.w3ctech.docpilot
# APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"   # [secret]

# --- Web(build 期内联,见 docker-compose.prod.yml 的 build args) ---
NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_APP_URL=https://app.example.com

# --- PostgreSQL(pgvector);托管则改为托管连接串 ---
DATABASE_URL=postgres://docpilot:change-me-strong@postgres:5432/docpilot   # [secret]
# 每进程连接池上限(api 与 worker 各一池)。缺省 20;上量前应在前面加 PgBouncer,
# 并据 Postgres max_connections 反推,别无脑调大直接压垮 PG。
DATABASE_POOL_MAX=20

# --- Redis;托管则改为托管连接串 ---
REDIS_URL=redis://redis:6379

# --- Worker ---
# 管线以等待 LLM 为主(I/O bound),并发可远高于代码默认 2;受上游网关 TPM/RPM 约束别调过高。
WORKER_CONCURRENCY=8
# worker 副本数(worker 无端口绑定可直接多副本)。总吞吐 ≈ WORKER_REPLICAS × WORKER_CONCURRENCY。
WORKER_REPLICAS=1
OUTBOX_POLL_INTERVAL_MS=2000

# --- 可观测性 ---
LOG_LEVEL=info
# 各进程独立命名空间,api 与 worker 可用同一端口。不设则不启动 /metrics。
# METRICS_PORT=9464

# --- 对象存储(自托管 MinIO;生产建议 Cloudflare R2 / AWS S3) ---
S3_ENDPOINT=http://minio:9000              # R2/S3 时改为其 endpoint
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=change-me-access-key      # [secret] 必填:缺失时 compose 拒绝启动(fail-fast)
S3_SECRET_ACCESS_KEY=change-me-strong      # [secret] 必填:缺失时 compose 拒绝启动(fail-fast)
S3_BUCKET=docpilot-private
S3_FORCE_PATH_STYLE=true                   # MinIO 用 true;R2/S3 视情况(多数用 false)
UPLOAD_URL_EXPIRES_SECONDS=900

# --- 邮件(登录验证码 SMTP) ---
# 注意:当前 packages/auth/src/mailer.ts 用无鉴权 SMTP(secure:false,无 user/pass)。
# 接真实邮件服务(需账号密码/TLS)前,需扩展 mailer;否则验证码发不出去。
SMTP_HOST=smtp.example.com
SMTP_PORT=587
MAIL_FROM=DocPilot <no-reply@example.com>

# --- AI Providers ---
# 不设则回落 mock(占位输出,不能用于生产)。生产必须配真实凭据。
# 方式 A(推荐):统一网关(new-api 等),一个令牌 + host 通吃文本与 embedding。
AI_GATEWAY_BASE_URL=https://new-api.lingowhale.com
AI_GATEWAY_API_KEY=                         # [secret]
# 方式 B:分别配官方 Key(显式配置优先,可覆盖单个 provider)。
# ANTHROPIC_API_KEY=                        # [secret]
# OPENAI_API_KEY=                           # [secret] 仅用官方 OpenAI embedding 时需要
# ⚠️ new-api 网关无 embedding 模型:embedding 需另配端点。
#    docker-compose.prod.yml 默认已带自托管 ollama 服务,api/worker 的 OPENAI_BASE_URL
#    默认就指向它(http://ollama:11434/v1,免 key),无需在此设置。
#    仅当改用官方 OpenAI / 其它端点时才在这里覆盖(并删掉 compose 里的 ollama / ollama-init)。
# OPENAI_BASE_URL=
# 模型名必须是网关/provider 上真实存在的名字。
# AI_ANSWER_MODEL=claude-opus-4-8
# AI_SUMMARIZE_MODEL=claude-opus-4-8
# Embedding 默认 bge-m3(1024 维,与 vector(1024) 一致);换维度须同步 schema + migration。
# AI_EMBEDDING_MODEL=bge-m3

# --- RAG ---
# 真实 embedding 分数为正,保持 0 即可(mock 伪向量才需要 -1)。
RAG_MIN_SCORE=0

# --- APNS(iOS 推送)---
# token-based(.p8 JWT)。三者齐全才启用;缺任一则 /admin/push-test 返回 503。
# APNS_PRIVATE_KEY 填 .p8 全文,单行用 \n 转义换行。
# APNS_TEAM_ID=XXXXXXXXXX
# APNS_KEY_ID=YYYYYYYYYY
# APNS_PRIVATE_KEY=                           # [secret] "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# APNS_BUNDLE_ID=dev.w3ctech.docpilot
