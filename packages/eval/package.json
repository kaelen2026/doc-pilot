{
  "name": "@doc-pilot/eval",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "eval": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.include=src/metrics.ts --coverage.thresholds.lines=85 --coverage.thresholds.functions=90 --coverage.thresholds.branches=75 --coverage.thresholds.statements=85"
  },
  "dependencies": {
    "@doc-pilot/ai": "workspace:*",
    "@doc-pilot/contracts": "workspace:*",
    "@doc-pilot/database": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@doc-pilot/config": "workspace:*",
    "@types/node": "^24.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
