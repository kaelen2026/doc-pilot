{
  "name": "@doc-pilot/observability",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.include='src/**/*.ts' --coverage.exclude='src/**/*.test.ts' --coverage.exclude=src/index.ts --coverage.thresholds.lines=80 --coverage.thresholds.functions=93 --coverage.thresholds.branches=89 --coverage.thresholds.statements=80"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-prometheus": "^0.220.0",
    "@opentelemetry/sdk-metrics": "^2.9.0"
  },
  "devDependencies": {
    "@doc-pilot/config": "workspace:*",
    "@opentelemetry/sdk-trace-base": "^2.10.0",
    "@types/node": "^24.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
