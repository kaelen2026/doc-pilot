{
  "name": "@doc-pilot/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.include=src/ai-generation.ts --coverage.thresholds.lines=80 --coverage.thresholds.functions=50 --coverage.thresholds.branches=70 --coverage.thresholds.statements=80"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@doc-pilot/ai": "workspace:*",
    "@doc-pilot/config": "workspace:*",
    "@types/node": "^24.0.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
