# Copy to .env and adjust as needed. Local defaults match docker-compose.yml.
# `pnpm dev` 下 api/worker 通过 tsx `--env-file-if-exists=../../.env` 自动加载本文件
# (缺失则跳过,回落各 env.ts 的本地默认值);web 走 apps/web/lib/env.ts 的默认值,无需本文件。

# --- API ---
API_PORT=3001
WEB_ORIGIN=http://localhost:3000

# --- Auth (Better Auth) ---
# 生产必须改为强随机值（如 openssl rand -base64 32）。
BETTER_AUTH_SECRET=dev-secret-change-me
BETTER_AUTH_URL=http://localhost:3001
# 逗号分隔；Apple 原生客户端使用 docpilot:// Origin。
AUTH_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:3001,docpilot://

# --- Web ---
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- PostgreSQL (pgvector) ---
DATABASE_URL=postgres://docpilot:docpilot@localhost:5432/docpilot

# --- Redis (BullMQ + 接口限流令牌桶) ---
REDIS_URL=redis://localhost:6379

# --- Worker ---
WORKER_CONCURRENCY=2

# --- 可观测性 (Observability, Phase 7) ---
# 日志级别:debug | info | warn | error(默认 info)。
LOG_LEVEL=info
# 设置后 API/Worker 各自用该端口暴露 Prometheus /metrics;不设则不启动(no-op)。
# 两个进程需用不同端口,例如 API=9464、Worker=9465。
# METRICS_PORT=9464
# Trace 导出默认关闭(withSpan 为 no-op);生产接入 OTLP 时按需注册 TracerProvider。

# --- Object storage (MinIO locally; S3-compatible in prod) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=docpilot-private
S3_FORCE_PATH_STYLE=true
UPLOAD_URL_EXPIRES_SECONDS=900

# --- Outbox publisher (worker) ---
OUTBOX_POLL_INTERVAL_MS=2000

# --- Mail (Mailpit SMTP locally) ---
SMTP_HOST=localhost
SMTP_PORT=1025
MAIL_FROM=DocPilot <no-reply@docpilot.local>

# --- AI providers (Phase 5+) ---
# 两种配法,任选其一:
#
# A) 统一网关(new-api 等,OpenAI + Anthropic 双兼容,一个令牌通吃)——推荐用于文本。
#    文本(摘要/问答)走 Anthropic 格式,embedding 走 OpenAI 兼容端点,共用同一令牌与 host。
#    BASE_URL 填网关 host(不带 /v1);/v1/messages 与 /v1/embeddings 由代码自动补齐。
# AI_GATEWAY_BASE_URL=https://new-api.lingowhale.com
# AI_GATEWAY_API_KEY=sk-xxxx
#
#    ⚠️ new-api.lingowhale.com 当前【没有 embedding 模型】。embedding 需另配端点:
#    本地推荐 Ollama(见 C),或配官方 OpenAI(OPENAI_API_KEY,配了就直连官方不误发网关)。
#
# B) 完全分别配官方 Key(各自直连官方端点)。显式 Key 优先于网关配置,可只覆盖单个 provider。
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# 需要单独指向自定义端点时(可选):
# ANTHROPIC_BASE_URL=
# OPENAI_BASE_URL=
#
# C) 本地 Ollama 作 embedding(自托管、免 API Key、零调用成本):
#    `ollama pull bge-m3`,然后设 OPENAI_BASE_URL 指向 Ollama 的 OpenAI 兼容端点。
#    配了 OPENAI_BASE_URL 即启用真实 embedding(无需 OPENAI_API_KEY)。
# OPENAI_BASE_URL=http://localhost:11434/v1
# AI_EMBEDDING_MODEL=bge-m3
#
# 未配置文本凭据时,摘要/问答回落 mock adapter(占位输出);
# 既无 embedding 凭据也无 OPENAI_BASE_URL 时,embedding 回落确定性哈希伪向量(仅本地/CI 用)。
#
# 模型名必须是网关/provider 上真实存在的名字(new-api 上按其后台配置的名称填)。
# 中转网关若不支持 adaptive thinking 参数导致 400,设为 none 关闭:
# AI_ANTHROPIC_THINKING=none
# AI_SUMMARIZE_MODEL=claude-opus-4-8
# AI_ANSWER_MODEL=claude-opus-4-8
# Embedding 默认 bge-m3(原生 1024 维,与 document_chunks.embedding 的 vector(1024) 一致)。
# 换成其它维度的模型(如 text-embedding-3-* 默认 1536)须同步改 schema + migration,否则 Worker 拦截。
# AI_EMBEDDING_MODEL=bge-m3

# --- RAG (Phase 6) ---
# 检索相似度下限 [0,1]。mock 伪向量的分数无语义,本地开发保持 0(不过滤);
# 接入真实 embedding 后可按评测调高(如 0.3)。
# RAG_MIN_SCORE=0
