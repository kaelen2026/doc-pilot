{
  "name": "@doc-pilot/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../../.env src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "backfill:embeddings": "tsx --env-file-if-exists=../../.env scripts/backfill-embeddings.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.coverage.config.ts --coverage.include='src/**/*.ts' --coverage.exclude='src/**/*.test.ts' --coverage.exclude='src/**/*.integration.test.ts' --coverage.exclude=src/index.ts --coverage.exclude=src/env.ts --coverage.thresholds.lines=55 --coverage.thresholds.functions=75 --coverage.thresholds.branches=80 --coverage.thresholds.statements=55"
  },
  "dependencies": {
    "@doc-pilot/ai": "workspace:*",
    "@doc-pilot/contracts": "workspace:*",
    "@doc-pilot/database": "workspace:*",
    "@doc-pilot/observability": "workspace:*",
    "@doc-pilot/push": "workspace:*",
    "@doc-pilot/queue": "workspace:*",
    "@doc-pilot/storage": "workspace:*",
    "bullmq": "^5.80.6",
    "drizzle-orm": "^0.45.2",
    "firebase-admin": "13.4.0",
    "ioredis": "^5.4.0",
    "postgres": "^3.4.9",
    "unpdf": "^1.6.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@doc-pilot/config": "workspace:*",
    "@types/node": "^24.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
