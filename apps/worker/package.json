{
  "name": "@doc-pilot/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../../.env src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "backfill:embeddings": "tsx --env-file-if-exists=../../.env scripts/backfill-embeddings.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage --coverage.include='src/pipeline/{chunk,clean,embed,errors,hash,summarize,tokens}.ts' --coverage.include=src/outbox/publisher.ts --coverage.include=src/reconcile/reconciler.ts --coverage.include=src/repository/processing-guard.ts --coverage.thresholds.lines=75 --coverage.thresholds.functions=70 --coverage.thresholds.branches=70 --coverage.thresholds.statements=75"
  },
  "dependencies": {
    "@doc-pilot/ai": "workspace:*",
    "@doc-pilot/contracts": "workspace:*",
    "@doc-pilot/database": "workspace:*",
    "@doc-pilot/observability": "workspace:*",
    "@doc-pilot/push": "workspace:*",
    "@doc-pilot/queue": "workspace:*",
    "@doc-pilot/storage": "workspace:*",
    "bullmq": "^5.80.6",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.4.0",
    "postgres": "^3.4.9",
    "unpdf": "^1.6.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@doc-pilot/config": "workspace:*",
    "@types/node": "^24.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
