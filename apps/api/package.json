{
  "name": "@doc-pilot/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../../.env src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --config vitest.coverage.config.ts --coverage.include='src/**/*.ts' --coverage.exclude='src/**/*.test.ts' --coverage.exclude='src/**/*.integration.test.ts' --coverage.exclude=src/index.ts --coverage.exclude=src/env.ts --coverage.thresholds.lines=57 --coverage.thresholds.functions=57 --coverage.thresholds.branches=80 --coverage.thresholds.statements=57",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1089.0",
    "@aws-sdk/s3-request-presigner": "^3.1089.0",
    "@doc-pilot/ai": "workspace:*",
    "@doc-pilot/auth": "workspace:*",
    "@doc-pilot/contracts": "workspace:*",
    "@doc-pilot/database": "workspace:*",
    "@doc-pilot/observability": "workspace:*",
    "@doc-pilot/push": "workspace:*",
    "@doc-pilot/queue": "workspace:*",
    "@doc-pilot/storage": "workspace:*",
    "@hono/node-server": "^1.14.0",
    "better-auth": "^1.6.23",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.30",
    "ioredis": "^5.4.0",
    "nodemailer": "^9.0.3",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@doc-pilot/config": "workspace:*",
    "@types/node": "^24.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
